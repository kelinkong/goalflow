# --- Backend (Spring Boot) ---
# Database configuration
DB_URL=jdbc:mysql://localhost:3306/goalflow?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
DB_USER=root
DB_PASSWORD=REDACTED_PASSWORD

# OpenAI / AI Configuration (for goal decomposition)
OPENAI_API_KEY=your_openai_api_key_here
# Optional: Customize the base URL for other providers (e.g., DashScope)
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Security
# A strong Base64 secret key for JWT signing (at least 256 bits)
JWT_SECRET=your_jwt_signing_secret_here

# --- Admin Console (Vue) ---
# Admin console API base URL
VITE_API_BASE_URL=http://localhost:8081

# --- Mobile (Flutter) ---
# Flutter API base URL (for local dev, use 10.0.2.2 for Android emulator)
API_BASE_URL=http://127.0.0.1:8081
